<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- USBеӯҳеӮЁи®ҝй—®жқғйҷҗ -->
    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    
    <!-- еӯҳеӮЁжқғйҷҗ - Android 9йңҖиҰҒ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    
    <!-- дҝқжҢҒеұҸе№•еёёдә®пјҲж’ӯж”ҫж—¶пјү -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".MediaHubApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        tools:targetApi="34">
        
        <!-- дё»Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- USBи®ҫеӨҮжҸ’е…ҘиҮӘеҠЁеј№еҮә -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>
        
        <!-- и§Ҷйў‘ж’ӯж”ҫActivity -->
        <activity
            android:name=".player.VideoPlayerActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="sensorLandscape"
            android:theme="@style/PlayerTheme" />
            
        <!-- е°ҸиҜҙйҳ…иҜ»Activity -->
        <activity
            android:name=".reader.NovelReaderActivity"
            android:configChanges="orientation|screenSize"
            android:theme="@style/ReaderTheme" />
            
        <!-- йҹійў‘ж’ӯж”ҫService -->
        <service
            android:name=".player.AudioPlayerService"
            android:exported="false">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>
        
    </application>

</manifest>
